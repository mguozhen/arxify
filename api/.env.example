# LLM keys (required)
ANTHROPIC_API_KEY=
MIROMIND_API_KEY=
ANTHROPIC_BASE_URL=          # optional — proxy like https://app.flatkey.ai

# Database (required in prod)
DATABASE_URL=postgresql://localhost:5432/arxify

# Redis (for arq workers)
REDIS_URL=redis://localhost:6379/0

# Stripe (required for paid plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SCHOLAR_MONTHLY=
STRIPE_PRICE_SCHOLAR_YEARLY=
STRIPE_PRICE_LAB_MONTHLY=
STRIPE_PRICE_LAB_YEARLY=

# Storage
AWS_REGION=us-west-2
AWS_S3_BUCKET=arxify-artifacts
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Pipeline locations (paths to forked repos)
AI_SCIENTIST_DIR=/opt/AI-Scientist-v2
AI_RESEARCHER_DIR=/opt/ai-researcher

# Frontend origin (CORS)
WEB_ORIGIN=http://localhost:3000

# Dev override — when set, bypass auth and use a dev user
# ARXIFY_DEV_USER=hunter@arxify.ai

# Run jobs inline (synchronously) instead of via arq — local dev only
# ARXIFY_INLINE_JOBS=1
